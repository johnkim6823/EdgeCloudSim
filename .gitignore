# ---------------------------------------------------------------------------
# Generated simulation / evaluation output -- never commit these, they're
# regenerated by running the simulators (scripts/*/run_scenarios.sh) and
# scripts/evaluate.py respectively.
# ---------------------------------------------------------------------------
# Raw simulation results, e.g. scripts/three_tier/output/, scripts/ReSACO/output/
# (bare pattern with no leading "/" matches at every directory depth, so this
# also covers the per-application output/ folders without needing a separate
# .gitignore in each scripts/<app>/ directory)
output*

# Evaluation results, e.g. scripts/evaluation_result/ReSACO_20260716/
evaluation_result

# Legacy per-app results/ folders (evaluate.py now writes to
# scripts/evaluation_result/ instead, but keep ignoring this in case older
# output is still lying around locally)
results
